<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SmartNotes" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/surface_light</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/background_light</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.SmartNotes.Button</item>
        <item name="textInputStyle">@style/Widget.SmartNotes.TextInputLayout</item>
        <item name="floatingActionButtonStyle">@style/Widget.SmartNotes.FAB</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.SmartNotes.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.SmartNotes.Medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Outlined Button Style -->
    <style name="Widget.SmartNotes.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="shapeAppearance">@style/ShapeAppearance.SmartNotes.Medium</item>
    </style>

    <!-- TextInputLayout Style -->
    <style name="Widget.SmartNotes.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearance">@style/ShapeAppearance.SmartNotes.Medium</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.SmartNotes.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="shapeAppearance">@style/ShapeAppearance.SmartNotes.Large</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/on_primary</item>
    </style>

    <!-- Shapes -->
    <style name="ShapeAppearance.SmartNotes.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.SmartNotes.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Text Appearances -->
    <style name="TextAppearance.SmartNotes.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.SmartNotes.Subtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>